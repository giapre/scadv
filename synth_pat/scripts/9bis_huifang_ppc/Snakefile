configfile: "config.yaml"

rule all:
    input:
        expand(
            "results/{sub}/bold_sweep/run_{i}.npz",
            sub=config["subjects"],
            i=range(config["n_runs"])
        )

rule run_simulation:
    output:
        "results/{sub}/bold_sweep/run_{i}.npz"
    shell:
        """
        python run_simulation.py {wildcards.sub} {wildcards.i} {output}
        """